APP_NAME="Finanz Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin
APP_URL=http://localhost:8000

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite: eine Datei = die komplette Datenbank (portabel zwischen Rechnern).
DB_CONNECTION=sqlite
DB_DATABASE=/app/database/finanz.sqlite

# Kein DB-Server, kein Redis: alles file-/sync-basiert. Single-User lokal.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
